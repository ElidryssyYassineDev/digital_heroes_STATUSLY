# Postgres connection string (Neon). Get this from your Neon project's
# "Connect" panel - use the pooled connection string for serverless.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Better Auth - generate with: npx @better-auth/cli secret
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud Console -> APIs & Services -> Credentials)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (email verification + password reset)
RESEND_API_KEY=""